# notApollo .gitignore

# Downloaded assets (regenerated by scripts)
fonts/google-sans-flex/*.woff2
icons/material-symbols/*.woff2
js/lib/chart.min.js

# Temporary files
*.tmp
*.log
*.pid

# Backup files
*~
*.bak
*.backup

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Development files
node_modules/
*.swp
*.swo
.vscode/
.idea/

# Build artifacts
build/
dist/
*.o
*.so
*.a

# Configuration overrides
config/local.conf
config/*.local